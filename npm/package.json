{
  "name": "super-admin",
  "version": "0.1.0",
  "description": "React admin utilities for SuperAdmin Rails gem",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": ">=1.9.0",
    "react": ">=18.0.0",
    "react-redux": ">=8.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@thoughtbot/superglue": "^1.0.3",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.3.0"
  },
  "license": "MIT"
}
